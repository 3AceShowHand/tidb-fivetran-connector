FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PROJECT_PATH=/workspace/tidb-fivetran-connector

WORKDIR /workspace/tidb-fivetran-connector

COPY tidb-fivetran-connector/ /workspace/tidb-fivetran-connector/

RUN pip install --no-cache-dir .

ENTRYPOINT ["python", "-m", "deployer.runner"]
